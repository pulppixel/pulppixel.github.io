---
interface Props {
  showBackLink?: boolean;
}
const { showBackLink = false } = Astro.props;
---

<nav>
  <a href="/" class="logo">pulppixel<span>.</span></a>
  <div class="nav-links">
    {showBackLink ? (
        <a href="/">돌아가기</a>
    ) : (
        <>
          <a href="#projects" class="hide-mobile">Projects</a>
          <a href="#career" class="hide-mobile">Career</a>
          <a href="#contact" class="hide-mobile">Contact</a>
        </>
    )}
    <!--<a href="/leaderboard/" class="lb-link">★</a>-->
    <a href="/explore/" class="explore-link">◆ 3D 월드</a>
    <a href="https://github.com/pulppixel/pulppixel.github.io" target="_blank" rel="noopener" class="github-link" aria-label="GitHub repository">
      <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
      </svg>
    </a>
    <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">◐</button>
  </div>
</nav>

<style>
  nav {
    position: fixed; top: 0; width: 100%; z-index: 100;
    padding: 0 2rem; height: 56px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg-primary) 85%, transparent);
  }
  .logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem; font-weight: 600;
    color: var(--text-primary); letter-spacing: -0.02em; text-decoration: none;
  }
  .logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 1.75rem; align-items: center; }
  .nav-links a {
    font-size: 0.8rem; color: var(--text-secondary);
    text-decoration: none; font-weight: 400;
    letter-spacing: 0.02em; transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text-primary); }
  .explore-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem !important;
    color: var(--accent) !important;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--accent-mid);
    border-radius: 4px;
    letter-spacing: 0.04em;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .explore-link:hover {
    background: var(--accent-dim);
    border-color: var(--accent);
  }
  .theme-toggle { background: var(--bg-card); border: 1px solid var(--border); color: var(--text-secondary); width: 32px; height: 32px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; transition: all 0.2s; }
  .theme-toggle:hover { border-color: var(--border-hover); color: var(--text-primary); }
  .github-link { background: var(--bg-card); border: 1px solid var(--border); color: var(--text-secondary); width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
  .github-link svg { display: block; }
  .github-link:hover { border-color: var(--border-hover); color: var(--text-primary); }
  @media (max-width: 768px) {
    nav { padding: 0 1.25rem; }
    .hide-mobile { display: none; }
  }
  .lb-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem !important;
    color: #fbbf24 !important;
    padding: 0.3rem 0.7rem;
    border: 1px solid rgba(251, 191, 36, 0.3);
    border-radius: 4px;
    letter-spacing: 0.06em;
    transition: all 0.2s;
  }
  .lb-link:hover {
    background: rgba(251, 191, 36, 0.08);
    border-color: rgba(251, 191, 36, 0.6);
  }
</style>