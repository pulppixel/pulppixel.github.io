---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Footer from '../components/Footer.astro';

const projects = [
  { slug:'eterna', title:'ETERNA — 아고라 시스템', period:'2025.11 — 2026.04', description:'디스코드형 커뮤니티 시스템의 아키텍처 설계부터 구현까지 전담.', tags:['Unity','C#','R3','UniTask','Tencent IM','FlatBuffers'], badge:'ARCHITECT', badgeColor:'green' as const },
  { slug:'haul', title:'HAUL — 2D PvPvE Extraction', period:'2025.10 — 현재', description:'Server-authoritative 멀티플레이어 게임. 1인 설계·구현 중.', tags:['Godot 4','C#','ASP.NET','gRPC','LiteNetLib'], badge:'IN PROGRESS', badgeColor:'yellow' as const },
  { slug:'reiw', title:'REIW — 3D 메타버스', period:'2025.06 — 2025.11', description:'채팅·친구 시스템 재설계, 하우징 프로토타입, NPC 퀘스트 구현.', tags:['Unity','C#','R3','UniTask','DOTween'] },
  { slug:'iw-zombie', title:'IW Zombie — 팀 서바이벌', period:'2025.02 — 2025.06', description:'5단계 게임 루프 전반과 Tencent IM 채팅 첫 도입.', tags:['Unity','C#','Tencent IM','DOTween'] },
  { slug:'stelsi-wallet', title:'STELSI Wallet', period:'2023.02 — 2023.08', description:'Unity → Flutter 스택 전환. Web3 + 스마트 컨트랙트. 양대 스토어 출시.', tags:['Flutter','Dart','Web3.js','ABI'], badge:'SOLO', badgeColor:'green' as const },
  { slug:'nomads-planet', title:'Nomads Planet', period:'2023.06 — 2023.09', description:'Unity Netcode + Vivox 멀티플레이어 메타버스. K-메타버스 경진대회 장려상.', tags:['Unity','C#','Netcode','Vivox'], badge:'수상', badgeColor:'purple' as const },
  { slug:'spody', title:'SPODY — XR 유아 교육', period:'2020.01 — 2021.06', description:'Kinect/ASTRA + OpenCV XR 교육 콘텐츠. 양산 체계 구축, 공공기관 납품.', tags:['Unity','C#','OpenCV','Kinect','ASTRA'], badge:'SOLO → LEAD', badgeColor:'green' as const },
  { slug:'ruby-adventure', title:'루비의 모험', period:'2019.09 — 2019.11', description:'1인 개발 3D 액션 RPG. 졸업전시 우수상.', tags:['Unity','C#','NavMesh','Timeline'], badge:'우수상', badgeColor:'purple' as const },
];
---

<BaseLayout title="Pulppixel Portfolio">
  <Nav />
  <Hero />

  <section id="projects" class="fade-in">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Selected Projects</div>
        <h2 class="section-title">프로젝트</h2>
      </div>
      <div class="project-grid">
        {projects.map(p => <ProjectCard {...p} />)}
      </div>
    </div>
  </section>

  <section id="contact" class="contact-section fade-in">
    <div class="container">
      <div class="contact-row">
        <div>
          <div class="section-label">Contact</div>
          <div class="contact-comment">// open to new connections</div>
        </div>
        <div class="contact-right">
          <a href="mailto:devenvy100@gmail.com">Email ↗</a>
          <a href="https://github.com/pulppixel" target="_blank" rel="noopener">GitHub ↗</a>
          <a href="https://www.linkedin.com/in/hwankee-baik-272948266/" target="_blank" rel="noopener">LinkedIn ↗</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .project-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .contact-section { padding: 4rem 0; border-top: 1px solid var(--border); }
  .contact-row { display: flex; justify-content: space-between; align-items: flex-end; }
  .contact-comment { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: var(--text-tertiary); }
  .contact-right { display: flex; gap: 1.5rem; }
  .contact-right a { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: var(--text-tertiary); text-decoration: none; transition: color 0.2s; }
  .contact-right a:hover { color: var(--accent); }
  @media (max-width: 768px) { .project-grid { grid-template-columns: 1fr; } .contact-row { flex-direction: column; align-items: flex-start; gap: 1.5rem; } }
</style>
