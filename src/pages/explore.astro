      const tint = Math.random();
      if (tint < 0.3) { starColors[i*3]=0.43; starColors[i*3+1]=0.91; starColors[i*3+2]=0.72; } // green
      else if (tint < 0.5) { starColors[i*3]=0.65; starColors[i*3+1]=0.55; starColors[i*3+2]=0.98; } // purple
      else { starColors[i*3]=0.7; starColors[i*3+1]=0.7; starColors[i*3+2]=0.75; } // white-ish
    }
