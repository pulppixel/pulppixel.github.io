---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    slug: 'eterna',
    title: 'ETERNA - 아고라 시스템',
    period: '2025.11 - 2026.04',
    description: '확장 가능한 커뮤니티 아키텍처 설계 및 구현 전담. (3-Tier Service/Repository/State 패턴 적용)',
    tags: ['Unity', 'C#', 'R3', 'UniTask', 'Tencent IM', 'FlatBuffers'],
    badge: 'ARCHITECT',
    badgeColor: 'green' as const,
  },
  {
    slug: 'reiw',
    title: 'REIW - 3D 메타버스',
    period: '2025.06 - 2025.11',
    description: 'Tencent IM 기반 채팅/친구 시스템 재설계, 하우징 프로토타입, NPC 퀘스트 구현. 채팅 및 소셜 시스템의 구조적 개선 및 재설계 (차세대 아키텍처의 프로토타이핑 수행)',
    tags: ['Unity', 'C#', 'R3', 'UniTask', 'DOTween'],
  },
  {
    slug: 'iw-zombie',
    title: 'IW Zombie - 팀 서바이벌',
    period: '2025.02 - 2025.06',
    description: '5단계 게임 루프 전반과 Tencent IM 채팅 첫 도입. 3D 사운드 풀링, 전투 로직, AI NPC, 범용 디버그 치트 시스템.',
    tags: ['Unity', 'C#', 'Tencent IM', 'DOTween'],
  },
  {
    slug: 'stelsi-wallet',
    title: 'STELSI Wallet',
    period: '2023.02 - 2023.08',
    description: 'Unity -> Flutter 스택 전환을 주도하고 1인 개발. Web3.js + 스마트 컨트랙트 연동, App Store / Google Play 출시.',
    tags: ['Flutter', 'Dart', 'Web3.js', 'ABI'],
    badge: 'SOLO',
    badgeColor: 'green' as const,
  },
  {
    slug: 'stelsi',
    title: 'STELSI - UE5 메타버스',
    period: '2023.08 - 2024.12',
    description: 'UE5 메타버스 프로젝트 중간 투입. Bink2 영상 재생, 360도 촬영 툴, UI, 외주 관리. SM그룹, 정림건축 MOU 기여.',
    tags: ['Unreal Engine 5', 'C++', 'Bink2'],
  },
  {
    slug: 'frenzy-circle',
    title: 'Nine to Six - 텔레그램 미니 게임',
    period: '2024.06 - 2024.10',
    description: 'TON 생태계 텔레그램 환경(WebGL) 미니 게임. 텔레그램 API 로그인, 코인 밈 테마, 랭킹 시스템.',
    tags: ['Unity', 'C#', 'WebGL', 'RESTful API'],
  },
  {
    slug: 'haul',
    title: 'HAUL - 2D PvPvE Extraction',
    period: '2025.10 - Present',
    description: 'Server-authoritative 멀티플레이어 게임. Client-side prediction, Server reconciliation, NPC AI를 1인 설계/구현.',
    tags: ['Godot 4', 'C#', 'ASP.NET', 'gRPC', 'LiteNetLib'],
    badge: 'IN PROGRESS',
    badgeColor: 'yellow' as const,
  },
  {
    slug: 'nomads-planet',
    title: 'Nomads Planet',
    period: '2023.06 - 2023.09',
    description: 'Unity Netcode + Vivox 기반 멀티플레이어 메타버스. K-메타버스 경진대회 장려상 수상.',
    tags: ['Unity', 'C#', 'Netcode', 'Vivox'],
    badge: '수상',
    badgeColor: 'purple' as const,
  },
  {
    slug: 'math-master',
    title: 'Math Master (일프로연산)',
    period: '2021.06 - 2022.06',
    description: '초등 수학 라이브 서비스. 분수 도메인 타입 설계, Recursive Backtracker + A* 알고리즘, 자체 Tween 라이브러리.',
    tags: ['Unity', 'C#', 'UGUI', 'DOTween', 'UniRx'],
    badge: 'SKT ZEM',
    badgeColor: 'green' as const,
  },
  {
    slug: 'spody',
    title: 'SPODY - XR 유아 교육',
    period: '2020.01 - 2021.06',
    description: 'Kinect/ASTRA 센서 + OpenCV 캘리브레이션 기반 XR 교육 콘텐츠. 유일한 개발자로 시작, 양산 체계 구축. 공공기관 납품.',
    tags: ['Unity', 'C#', 'OpenCV', 'Kinect', 'ASTRA'],
    badge: 'SOLO -> LEAD',
    badgeColor: 'green' as const,
  },
  {
    slug: 'ruby-adventure',
    title: '루비의 모험',
    period: '2019.09 - 2019.11',
    description: '1인 개발 3D 액션 RPG. 콤보/스킬 전투, BT 기반 몬스터 AI, 2페이즈 보스, Timeline 연출. 졸업전시 우수상.',
    tags: ['Unity', 'C#', 'NavMesh', 'Timeline'],
    badge: '우수상',
    badgeColor: 'purple' as const,
  },
];

const timeline = [
  {
    company: 'VOYAGER',
    role: 'Game Client Engineer / 서브 리드',
    period: '2025.02 - 2026.04 / 1년 3개월',
    projects: [
      'ETERNA - 실시간 커뮤니티 플랫폼 (아고라 시스템 전담)',
      'REIW - 3D 메타버스 (채팅 재설계, 하우징)',
      'IW Zombie - 팀 서바이벌 (게임 루프 전반)',
    ],
    current: true,
  },
  {
    company: 'VERS.',
    role: 'Unity Client Developer',
    period: '2022.06 - 2024.12 / 2년 7개월',
    projects: [
      'STELSI Wallet - 이더리움 지갑 앱 (Flutter)',
      'Nine to Six - 텔레그램 미니 게임 (WebGL)',
      'STELSI - UE5 메타버스 (Bink2 영상, 360도 촬영 툴, 외주 관리)',
    ],
  },
  {
    company: 'Math Master',
    role: 'Unity Client Developer',
    period: '2021.06 - 2022.06 / 1년 1개월',
    projects: [
      '일프로연산 - 초등 수학 라이브 서비스 (SKT ZEM 선정)',
      '분수 도메인 타입 설계 (연산자 오버로딩, GCD/LCM, 약분/채점 로직)',
      '미로 생성(Recursive Backtracker) + 탐색(A*) 알고리즘 구현',
      '자체 Tween 라이브러리 (Ease/Loop/Coroutine 기반, DOTween 대체)',
    ],
  },
  {
    company: 'VVR',
    role: 'Unity Client Developer / 초기 1인',
    period: '2020.01 - 2021.06 / 1년 6개월',
    projects: [
      '스포디 - XR 유아 교육 콘텐츠 (양산 체계 구축, 공공기관 납품)',
      'Kinect/ASTRA 센서 파이프라인 + OpenCV 자동 캘리브레이션 설계',
    ],
  },
];

const education = [
  {
    school: '홍익대학교',
    major: '게임학부 게임소프트웨어전공',
    period: '2014 - 2020',
  },
  {
    school: '백신고등학교',
    major: '인문계 (이과)',
    period: '2010 - 2013',
  },
];

const awards = [
  { title: 'K-메타버스 경진대회 장려상', org: '과학기술정보통신부', year: '2023' },
  { title: '정보처리기사', org: '한국산업인력공단', year: '2022' },
  { title: '졸업작품전시 우수상', org: '홍익대학교 게임학부', year: '2019' },
];
---

<BaseLayout title="pulppixel.">
  <Nav />
  <Hero />

  <!-- PROJECTS -->
  <section id="projects" class="fade-in">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Selected Projects</div>
        <h2 class="section-title">프로젝트</h2>
      </div>
      <div class="project-grid">
        {projects.map(p => <ProjectCard {...p} />)}
      </div>
    </div>
  </section>

  <!-- CAREER -->
  <section id="career" class="fade-in">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Career</div>
        <h2 class="section-title">경력</h2>
      </div>
      <div class="timeline">
        {timeline.map((item, i) => (
            <div class={`timeline-item ${i === 0 ? 'current' : ''}`}>
              <div class="timeline-company">{item.company}</div>
              <div class="timeline-role">{item.role}</div>
              <div class="timeline-period">{item.period}</div>
              <div class="timeline-projects">
                {item.projects.map(p => <span>{p}</span>)}
              </div>
            </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section id="skills" class="fade-in">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Tech Stack</div>
        <h2 class="section-title">기술</h2>
      </div>
      <div class="skills-grid">
        <div class="skill-group">
          <h4>Engine & Language</h4>
          <ul>
            <li>Unity (C#)</li>
            <li>Unreal Engine 5 (C++)</li>
            <li>Godot 4 (.NET / GDScript)</li>
            <li>Flutter (Dart)</li>
          </ul>
        </div>
        <div class="skill-group">
          <h4>Architecture & Network</h4>
          <ul>
            <li>Service / Repository / State</li>
            <li>R3 / UniRx Reactive</li>
            <li>Unity Netcode, Tencent IM SDK</li>
            <li>FlatBuffers, gRPC (MagicOnion)</li>
            <li>LiteNetLib (UDP)</li>
          </ul>
        </div>
        <div class="skill-group">
          <h4>Tools & Workflow</h4>
          <ul>
            <li>Git (Flow, Submodule)</li>
            <li>Jira, Confluence, Notion</li>
            <li>Android / iOS Native Bridge</li>
            <li>WebGL, UaaL</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- EDUCATION & AWARDS -->
  <section id="education" class="fade-in">
    <div class="container">
      <div class="two-col">
        <div>
          <div class="section-header">
            <div class="section-label">Education</div>
            <h2 class="section-title">학력</h2>
          </div>
          {education.map(e => (
              <div class="edu-item">
                <div class="edu-school">{e.school}</div>
                <div class="edu-major">{e.major}</div>
                <div class="edu-period">{e.period}</div>
              </div>
          ))}
        </div>
        <div>
          <div class="section-header">
            <div class="section-label">Awards & Cert</div>
            <h2 class="section-title">수상 / 자격</h2>
          </div>
          <div class="awards-list">
            {awards.map(a => (
                <div class="award-item">
                  <span class="award-year">{a.year}</span>
                  <div>
                    <div class="award-title">{a.title}</div>
                    <div class="award-org">{a.org}</div>
                  </div>
                </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <Testimonials />

  <!-- CONTACT -->
  <section id="contact" class="contact-section fade-in">
    <div class="container">
      <div class="contact-row">
        <div class="contact-left">
          <div class="section-label">Contact</div>
          <div class="contact-comment">// open to new connections</div>
        </div>
        <div class="contact-right">
          <div class="contact-group">
            <a href="mailto:devenvy100@gmail.com">Email</a>
            <a href="https://github.com/pulppixel" target="_blank" rel="noopener">GitHub</a>
            <a href="https://www.linkedin.com/in/hwankee-baik-272948266/" target="_blank" rel="noopener">LinkedIn</a>
          </div>
          <div class="contact-divider"></div>
          <div class="contact-group">
            <a href="/leaderboard/" class="contact-action" style="--c: #fbbf24;">리더보드</a>
            <a href="/guestbook/" class="contact-action" style="--c: #a78bfa;">방명록</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* PROJECT GRID */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  /* TIMELINE */
  .timeline {
    position: relative;
    padding-left: 2rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 3px; top: 8px; bottom: 8px;
    width: 1px;
    background: var(--border);
  }
  .timeline-item {
    position: relative;
    padding-bottom: 2.5rem;
  }
  .timeline-item:last-child { padding-bottom: 0; }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -2rem; top: 8px;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--border-hover);
    border: 2px solid var(--bg-primary);
  }
  .timeline-item.current::before { background: var(--accent); }
  .timeline-company {
    font-family: 'Outfit', 'Noto Sans KR', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.15rem;
  }
  .timeline-role {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.1rem;
  }
  .timeline-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-tertiary);
    margin-bottom: 0.75rem;
  }
  .timeline-projects {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .timeline-projects span {
    font-size: 0.82rem;
    color: var(--text-secondary);
    font-weight: 300;
  }
  .timeline-projects span::before {
    content: '-> ';
    color: var(--text-tertiary);
  }

  /* SKILLS */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .skill-group h4 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .skill-group ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .skill-group li {
    font-size: 0.88rem;
    color: var(--text-secondary);
    font-weight: 300;
  }

  /* EDUCATION & AWARDS */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }
  .edu-item { margin-bottom: 1rem; }
  .edu-school {
    font-family: 'Outfit', 'Noto Sans KR', sans-serif;
    font-size: 1rem;
    font-weight: 600;
  }
  .edu-major {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 300;
  }
  .edu-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-tertiary);
    margin-top: 0.2rem;
  }
  .awards-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .award-item {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }
  .award-year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-tertiary);
    flex-shrink: 0;
    min-width: 2.5rem;
  }
  .award-title {
    font-size: 0.9rem;
    font-weight: 500;
  }
  .award-org {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    font-weight: 300;
  }

  /* CONTACT */
  .contact-section { padding: 4rem 0; border-top: 1px solid var(--border); }
  .contact-row { display: flex; justify-content: space-between; align-items: flex-end; gap: 1.5rem; }
  .contact-left .section-label { margin-bottom: 0.5rem; }
  .contact-comment { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: var(--text-tertiary); }
  .contact-right { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
  .contact-group { display: flex; gap: 1.25rem; align-items: center; }
  .contact-divider { width: 1px; height: 14px; background: var(--border); }
  .contact-right a { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: var(--text-tertiary); text-decoration: none; transition: color 0.2s; }
  .contact-right a:hover { color: var(--accent); }
  .contact-action { font-size: 0.7rem !important; color: var(--c) !important; padding: 0.4rem 0.85rem; border: 1px solid color-mix(in srgb, var(--c) 35%, transparent); border-radius: 4px; letter-spacing: 0.04em; transition: all 0.2s !important; }
  .contact-action:hover { background: color-mix(in srgb, var(--c) 12%, transparent); border-color: var(--c); color: var(--c) !important; }

  @media (max-width: 768px) {
    .project-grid { grid-template-columns: 1fr; }
    .skills-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .two-col { grid-template-columns: 1fr; gap: 2.5rem; }
    .contact-row { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
    .contact-divider { display: none; }
  }

  .explore-contact-link { color: var(--accent) !important; }
</style>