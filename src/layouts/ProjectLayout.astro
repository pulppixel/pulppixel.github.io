---
interface Props {
  title: string;
  subtitle: string;
  period: string;
  role: string;
  team?: string;
  tags: string[];
  links?: { label: string; url: string }[];
  badge?: string;
  ogImage?: string;
}

import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const { title, subtitle, period, role, team, tags, links, badge, ogImage } = Astro.props;

// 프로젝트 순서 (index.astro와 동일)
const projectOrder = [
  { slug: 'eterna', title: 'ETERNA' },
  { slug: 'reiw', title: 'REIW' },
  { slug: 'iw-zombie', title: 'IW Zombie' },
  { slug: 'stelsi-wallet', title: 'STELSI Wallet' },
  { slug: 'stelsi', title: 'STELSI UE5' },
  { slug: 'frenzy-circle', title: 'Nine to Six' },
  { slug: 'haul', title: 'HAUL' },
  { slug: 'nomads-planet', title: 'Nomads Planet' },
  { slug: 'math-master', title: 'Math Master' },
  { slug: 'spody', title: 'SPODY' },
  { slug: 'ruby-adventure', title: '루비의 모험' },
];

const currentSlug = Astro.url.pathname.replace(/^\/projects\//, '').replace(/\/$/, '');
const currentIdx = projectOrder.findIndex(p => p.slug === currentSlug);
const prev = currentIdx > 0 ? projectOrder[currentIdx - 1] : null;
const next = currentIdx < projectOrder.length - 1 ? projectOrder[currentIdx + 1] : null;

// Slug -> minigame key (kept in sync with scripts/core/data.ts).
// Renders a "play minigame" CTA only for projects that have one.
const minigameMap: Record<string, string> = {
  'eterna':         'guestbook',
  'math-master':    'maze',
  'spody':          'spody',
  'ruby-adventure': 'ruby',
  'nomads-planet':  'nomads',
  'frenzy-circle':  'ninetosix',
  'haul':           'haul',
};
const minigameKey = minigameMap[currentSlug];
---

<BaseLayout title={`${title} - Pulppixel`} description={subtitle} ogImage={ogImage}>
  <Nav showBackLink={true} />

  <article class="project-detail">
    <div class="container">

      <!-- HEADER -->
      <header class="detail-header">
        <div class="detail-meta">
          <span class="detail-period">{period}</span>
          {badge && <span class="detail-badge">{badge}</span>}
        </div>
        <h1>{title}</h1>
        <p class="detail-subtitle">{subtitle}</p>

        <div class="detail-info">
          <div class="info-item">
            <span class="info-label">역할</span>
            <span class="info-value">{role}</span>
          </div>
          {team && (
              <div class="info-item">
                <span class="info-label">팀</span>
                <span class="info-value">{team}</span>
              </div>
          )}
          <div class="info-item">
            <span class="info-label">스택</span>
            <div class="info-tags">
              {tags.map(t => <span>{t}</span>)}
            </div>
          </div>
          {links && links.length > 0 && (
              <div class="info-item">
                <span class="info-label">링크</span>
                <div class="info-links">
                  {links.map(l => <a href={l.url} target="_blank" rel="noopener">{l.label}</a>)}
                </div>
              </div>
          )}
          {minigameKey && (
              <div class="info-item">
                <span class="info-label">체험</span>
                <a class="minigame-cta" href={`/play/${minigameKey}/`}>
                  <span class="cta-icon">🎮</span>
                  <span class="cta-text">미니게임 하러 가기</span>
                  <span class="cta-arrow">→</span>
                </a>
              </div>
          )}
        </div>
      </header>

      <!-- CONTENT (slot) -->
      <div class="detail-content">
        <slot />
      </div>

      <!-- PREV / NEXT -->
      <nav class="project-nav">
        {prev ? (
            <a href={`/projects/${prev.slug}/`} class="nav-prev">
              <span class="nav-dir">이전</span>
              <span class="nav-title">{prev.title}</span>
            </a>
        ) : <div />}
        {next ? (
            <a href={`/projects/${next.slug}/`} class="nav-next">
              <span class="nav-dir">다음</span>
              <span class="nav-title">{next.title}</span>
            </a>
        ) : <div />}
      </nav>

    </div>
  </article>

  <Footer />
</BaseLayout>

<style>
  .project-detail {
    padding-top: calc(56px + 4rem);
    padding-bottom: 4rem;
  }

  .detail-header {
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }
  .detail-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .detail-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .detail-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid var(--accent-mid);
  }

  .detail-header h1 {
    font-family: 'Outfit', 'Pretendard Variable', sans-serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }
  .detail-subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    font-weight: 400;
    line-height: 1.7;
    max-width: 640px;
  }

  .detail-info {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .info-item {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }
  .info-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    min-width: 3rem;
    flex-shrink: 0;
  }
  .info-value {
    font-size: 0.88rem;
    color: var(--text-secondary);
  }
  .info-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .info-tags span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    padding: 0.2rem 0.55rem;
    background: var(--tag-bg);
    border: 1px solid var(--tag-border);
    border-radius: 4px;
    color: var(--text-secondary);
  }
  .info-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .info-links a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .info-links a:hover { opacity: 0.7; }

  .minigame-cta { display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.55rem 0.95rem; background: var(--accent-dim); border: 1px solid var(--accent-mid); border-radius: 6px; color: var(--accent); font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; text-decoration: none; transition: all 0.2s; }
  .minigame-cta:hover { background: var(--accent-mid); transform: translateX(2px); box-shadow: 0 0 16px var(--accent-dim); }
  .minigame-cta .cta-icon { font-size: 0.95rem; }
  .minigame-cta .cta-arrow { display: inline-block; opacity: 0.6; transform: translateY(-1px); transition: opacity 0.2s, transform 0.2s; }
  .minigame-cta:hover .cta-arrow { opacity: 1; transform: translateY(-1px) translateX(2px); }

  /* CONTENT AREA */
  .detail-content {
    max-width: 720px;
  }
  .detail-content :global(h2) {
    font-family: 'Outfit', 'Pretendard Variable', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }
  .detail-content :global(h2:first-child) {
    margin-top: 0;
  }
  .detail-content :global(p) {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.8;
    font-weight: 400;
    margin-bottom: 1rem;
  }
  .detail-content :global(ul) {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }
  .detail-content :global(li) {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.75;
    font-weight: 400;
    padding-left: 1rem;
    position: relative;
  }
  .detail-content :global(li::before) {
    content: '-';
    position: absolute;
    left: 0;
    color: var(--text-tertiary);
  }
  .detail-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    background: var(--tag-bg);
    border: 1px solid var(--tag-border);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
  }
  .detail-content :global(img) {
    border-radius: 8px;
    border: 1px solid var(--border);
    margin: 1.5rem 0;
  }
  .detail-content :global(.media-placeholder) {
    background: var(--bg-card);
    border: 1px dashed var(--border-hover);
    border-radius: 8px;
    padding: 3rem 2rem;
    text-align: center;
    color: var(--text-tertiary);
    font-size: 0.82rem;
    font-family: 'JetBrains Mono', monospace;
    margin: 1.5rem 0;
  }

  /* PREV / NEXT NAV */
  .project-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    gap: 1rem;
  }
  .project-nav a {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: all 0.2s;
    min-width: 140px;
  }
  .project-nav a:hover {
    border-color: var(--border-hover);
    background: var(--bg-card);
  }
  .nav-prev { align-items: flex-start; }
  .nav-next { align-items: flex-end; }
  .nav-dir {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: var(--text-tertiary);
    letter-spacing: 0.04em;
  }
  .nav-title {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 500;
  }
  .project-nav a:hover .nav-title { color: var(--accent); }

  @media (max-width: 768px) {
    .info-item { flex-direction: column; gap: 0.25rem; }
    .info-label { min-width: auto; }
    .project-nav { flex-direction: column; }
    .nav-next { align-items: flex-start; }
  }
</style>