    },{passive:false});

    // ─── GAME STATE ───
    const mv=new THREE.Vector3();const SP=4.8;
    let started=false,nP=null;
    const heroLabel=document.getElementById('hero-label');
    const ih=document.getElementById('interact-hint');
    const pl=document.getElementById('project-label');
    const mi=document.getElementById('mobile-interact');
    const cLO=new THREE.Vector3(0,0.8,0);
    const cC=ch.position.clone().add(new THREE.Vector3(0,3,5));
    const cLC=ch.position.clone().add(cLO);
    camera.position.copy(cC);

    // ─── LOOP ───
    const clk=new THREE.Clock();let fc=0,flt=performance.now();const fps=document.getElementById('fps');

    function animate(){
      requestAnimationFrame(animate);
      const dt=Math.min(clk.getDelta(),0.05),t=clk.getElapsedTime();

      mv.set(0,0,0);let moving=false;
      if(keys['KeyW']||keys['ArrowUp'])mv.z-=1;
      if(keys['KeyS']||keys['ArrowDown'])mv.z+=1;
      if(keys['KeyA']||keys['ArrowLeft'])mv.x-=1;
      if(keys['KeyD']||keys['ArrowRight'])mv.x+=1;
      if(moveTid!==null){mv.x+=jIn.x;mv.z+=jIn.y;}

      if(mv.length()>0.12){
        if(!started){started=true;heroLabel.classList.add('hidden');}
        mv.normalize().applyAxisAngle(new THREE.Vector3(0,1,0),yaw);
        ch.position.x=Math.max(-30,Math.min(30,ch.position.x+mv.x*SP*dt));
        ch.position.z=Math.max(-30,Math.min(30,ch.position.z+mv.z*SP*dt));
        const tr=Math.atan2(mv.x,mv.z);let df=tr-ch.rotation.y;
        while(df>Math.PI)df-=Math.PI*2;while(df<-Math.PI)df+=Math.PI*2;
        ch.rotation.y+=df*8*dt; moving=true;
      }

      // ── CHARACTER ANIMATION ──
      const wp=moving?t*10:0,sw=moving?Math.sin(wp):0;
      lL.rotation.x=sw*0.5;lR.rotation.x=-sw*0.5;sL.rotation.x=sw*0.3;sR.rotation.x=-sw*0.3;
      aL.rotation.x=-sw*0.45;aR.rotation.x=sw*0.45;hL.rotation.x=-sw*0.45;hR.rotation.x=sw*0.45;
      // Knee pads follow legs
      kneeL.rotation.x=sw*0.3;kneeR.rotation.x=-sw*0.3;

      // Idle breathing + sway
      const breathe = Math.sin(t * 2) * 0.015;
      const idleSway = Math.sin(t * 0.8) * 0.02;
      const bob=moving?Math.abs(Math.sin(wp))*0.05:breathe;
      bd.position.y=0.66+bob;hd.position.y=1.08+bob;vs.position.y=1.1+bob;cp.position.y=0.72+bob;
      eL.position.y=1.1+bob;eR.position.y=1.1+bob;
      belt.position.y=0.44+bob*0.5;buckle.position.y=0.44+bob*0.5;
      bpBody.position.y=0.72+bob;bpScreen.position.y=0.76+bob;
      shL.position.y=0.88+bob;shR.position.y=0.88+bob;
      earL.position.y=1.1+bob;earR.position.y=1.1+bob;
      antBase.position.y=1.3+bob;antTip.position.y=1.4+bob;

      // Idle: arms sway gently, slight body rotation
      if(!moving){
        aL.rotation.x=idleSway;aR.rotation.x=-idleSway;
        aL.rotation.z=-0.06;aR.rotation.z=0.06;
        hL.rotation.x=idleSway;hR.rotation.x=-idleSway;
      }else{
        aL.rotation.z=0;aR.rotation.z=0;
      }

      // Antenna: gentle sway + tip pulse
      antBase.rotation.z=Math.sin(t*1.5)*0.1+(moving?sw*0.08:0);
      antTip.position.x=0.08+Math.sin(t*1.5)*0.015;
      antTip.material.color.setHSL(0.45,0.8,0.5+Math.sin(t*3)*0.15);
      antLight.intensity=0.3+Math.sin(t*3)*0.15;

      // Backpack screen flicker
      bpScreen.material.emissiveIntensity=1.5+Math.sin(t*5)*0.5;
      bpLight.intensity=0.2+Math.sin(t*5)*0.1;

      // Shoe sole glow pulse (subtle)
      soleL.material.emissiveIntensity=1.2+(moving?Math.abs(sw)*0.5:Math.sin(t*2)*0.2);
      soleR.material.emissiveIntensity=1.2+(moving?Math.abs(-sw)*0.5:Math.sin(t*2)*0.2);

      // Eye blink — MORE VISIBLE: longer blink, scale whole eye to 0, plus glow off
      const blinkCycle = t % 3.5; // every 3.5 seconds
      const isBlinking = blinkCycle > 3.2 && blinkCycle < 3.4;
      const blinkVal = isBlinking ? 0 : 1;
      eL.scale.y = blinkVal; eR.scale.y = blinkVal;
      eL.visible = !isBlinking; eR.visible = !isBlinking;
      eyeGlowL.intensity = isBlinking ? 0 : 0.3;
      eyeGlowR.intensity = isBlinking ? 0 : 0.3;
      // Double blink sometimes
      const dblBlink = t % 7 > 6.6 && t % 7 < 6.75;
      if(dblBlink){ eL.visible=false; eR.visible=false; eyeGlowL.intensity=0; eyeGlowR.intensity=0; }

      // Nearest
      nP=null;let nd=Infinity;
      pms.forEach(m=>{const dx=ch.position.x-m.position.x,dz=ch.position.z-m.position.z,d=Math.sqrt(dx*dx+dz*dz);if(d<2.4&&d<nd){nd=d;nP=m;}});

      if(nP){const p=nP.userData.project;let lb=`${p.title} — ${p.sub}`;if(p.badge)lb+=` <span class="lbl-badge" style="background:${p.bc}22;color:${p.bc};border:1px solid ${p.bc}44;">${p.badge}</span>`;lb+=`<div class="lbl-period">${p.period}</div>`;pl.innerHTML=lb;pl.style.display='block';ih.classList.add('show');mi.classList.add('show');}
      else{pl.style.display='none';ih.classList.remove('show');mi.classList.remove('show');}

      if(keys['KeyE']&&nP&&!panel.classList.contains('open')){openP(nP.userData.project,nP.userData.index);keys['KeyE']=false;}

      pms.forEach((m,i)=>{
        m.position.y=m.userData.baseY+Math.sin(t*1.5+i*0.8)*0.12;
        m.rotation.y=t*0.35;
        const n=m===nP;
        const ts=n?1.25:1;
        m.scale.setScalar(m.scale.x+(ts-m.scale.x)*0.08);
        // Cube brightness follows zone proximity
        const zi=m.userData.zone!==undefined?m.userData.zone:-1;
        const zp=zi>=0?zones[zi].proximity:0.3;
        const baseEi=zp*0.6;
        const tei=n?1.2+Math.sin(t*4)*0.4:baseEi;
        m.material.emissiveIntensity+=(tei-m.material.emissiveIntensity)*0.1;
        // Edge opacity follows zone
        if(m.children[0]&&m.children[0].material)m.children[0].material.opacity=zp*0.3;
      });

      // ── ZONE PROXIMITY + ACTIVATION ──
      const ZONE_R = 6;   // start sensing
      const ZONE_IN = 4;  // fully inside
      zones.forEach((z,zi)=>{
        const dx=ch.position.x-z.cx, dz=ch.position.z-z.cz;
        const dist=Math.sqrt(dx*dx+dz*dz);
        // 0 at ZONE_R+, 1 at ZONE_IN
        const prox = Math.max(0, Math.min(1, (ZONE_R-dist)/(ZONE_R-ZONE_IN)));
        z.proximity += (prox - z.proximity) * 4 * dt; // smooth lerp

        const p = z.proximity;
        const isIn = p > 0.85;

        // Activation trigger
        if(isIn && !z.active){
          z.active=true; z.activationTime=t;
        }
        if(!isIn) z.active=false;

        // ── Zone infrastructure responds to proximity ──
        // Platform glow: dim→bright
        z.platform.material.emissiveIntensity = 0.02 + p * 0.15;
        // Ring opacity
        z.ring.material.opacity = 0.06 + p * 0.2;
        // Floor fill
        z.fill.material.opacity = 0.01 + p * 0.04;
        // Pillar light
        z.pillarLight.intensity = 0.15 + p * 0.6;
        z.pillar.material.emissiveIntensity = 0.2 + p * 0.5;

        // ── Burst ring (팡! effect) ──
        const burst = z.burstRing;
        if(z.active && !z.wasActive){
          // JUST ACTIVATED → start burst
          burst.scale.setScalar(1);
          burst.material.opacity = 0.6;
        }
        if(z.active){
          const age = t - z.activationTime;
          const burstProgress = Math.min(age * 1.8, 1); // 0→1 in ~0.55s
          burst.scale.setScalar(1 + burstProgress * 7);
          burst.material.opacity = 0.6 * (1 - burstProgress);
          if(burstProgress >= 1){ burst.scale.setScalar(0); burst.material.opacity = 0; }
        }
        z.wasActive = z.active;
      });

      // ── ZONE DECORATIONS ANIM (proximity-scaled) ──
      zoneAnims.forEach(a=>{
        const m=a.mesh;
        const zi=a.zone!==undefined?a.zone:0;
        const p=zones[zi].proximity;

        // Scale decorations by proximity (dormant→alive)
        const targetScale = 0.15 + p * 0.85; // 15% when far, 100% when inside
        if(m.scale){
          const cs = m.scale.x;
          const ns = cs + (targetScale - cs) * 3 * dt;
          m.scale.setScalar(ns);
        }

        // Opacity/emissive modulation
        if(m.material){
          if(m.material.emissiveIntensity!==undefined){
            m.material.emissiveIntensity *= (0.1 + p * 0.9);
          }
          if(m.material.opacity!==undefined && a.type!=='pulse'){
            m.material.opacity *= (0.1 + p * 0.9);
          }
        }

        // Position animation (only when visible enough)
        const animStrength = Math.max(0, (p-0.1)/0.9);
        if(a.type==='float'){
          m.position.y=a.baseY+Math.sin(t*a.speed+(a.phase||0))*a.range*animStrength;
        }else if(a.type==='bounce'){
          m.position.y=a.baseY+Math.abs(Math.sin(t*a.speed+(a.phase||0)))*a.range*animStrength;
        }else if(a.type==='spin'){
          if(a.axis==='z')m.rotation.z=t*a.speed*animStrength;
          else if(a.axis==='y')m.rotation.y=t*a.speed*animStrength;
          else m.rotation.x=t*a.speed*animStrength;
          if(a.float)m.position.y=a.baseY+Math.sin(t*0.8)*a.float*animStrength;
        }else if(a.type==='pulse'){
          m.material.opacity=a.baseOp*p+Math.sin(t*2)*a.range*p;
        }
      });

      // Camera
      const dO=new THREE.Vector3(0,camDist*0.55,camDist).applyAxisAngle(new THREE.Vector3(0,1,0),yaw);
      cC.lerp(ch.position.clone().add(dO),4*dt);
      cLC.lerp(ch.position.clone().add(cLO),6*dt);
      camera.position.copy(cC);camera.lookAt(cLC);

      // Particles
      const pa=pG.attributes.position.array;
      for(let i=0;i<pC;i++){pa[i*3+1]+=0.003;if(pa[i*3+1]>15)pa[i*3+1]=0;}
      pG.attributes.position.needsUpdate=true;

      // Star twinkle
      const sOp = starGeo.getAttribute('color');
      for(let i=0;i<starCount;i+=8){
        const flicker = 0.4 + Math.sin(t*1.5+i*0.3)*0.3;
        sOp.array[i*3] *= (0.95+flicker*0.05);
      }
      sOp.needsUpdate = true;

      renderer.render(scene,camera);
      fc++;const now=performance.now();if(now-flt>=1000){fps.textContent=fc+' fps';fc=0;flt=now;}
    }
    animate();
    window.addEventListener('resize',()=>{camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();renderer.setSize(innerWidth,innerHeight);});
  </script>
</body>
</html>