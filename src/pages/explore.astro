    // ─── MOBILE TOUCH (Mabinogi Mobile Style) ───
    //
    //  화면 하단 50% = 이동 (다이나믹 조이스틱)
    //  화면 상단 50% = 회전 (드래그 델타)
    //  이동 중 다른 손 어디든 = 회전
    //  두 손가락 핀치 = 줌 (이동과 병행)
    //
    // ═════════════════════════════════════════════════════════
    const jBase=document.getElementById('joystick-base');
    const jThumb=document.getElementById('joystick-thumb');

    let moveTid=null;        // 이동 터치 ID
    let moveOrig={x:0,y:0};  // 조이스틱 중심 (터치 시작점)
    let jIn={x:0,y:0};       // 정규화된 조이스틱 출력

    let camTid=null;          // 회전 터치 ID
    let camPrev={x:0,y:0};   // 회전 이전 위치

    let pinchOn=false;
    let pinchBase=0;
    const JR=55; // 조이스틱 반경 (110/2)
    const MZ=0.65; // 하단 35% (0.65 = 상단 65%가 회전 영역)

    function pDist(a,b){return Math.sqrt((a.clientX-b.clientX)**2+(a.clientY-b.clientY)**2);}

    renderer.domElement.addEventListener('touchstart',e=>{
      e.preventDefault();
      if(panel.classList.contains('open'))return;

      // 핀치 시작
      if(e.touches.length>=2){
        pinchOn=true;
        pinchBase=pDist(e.touches[0],e.touches[1]);
        return;
      }

      const t=e.changedTouches[0];
      const yr=t.clientY/innerHeight;

      if(moveTid===null && yr>=MZ){
        // ── 이동 (하단) ──
        moveTid=t.identifier;
        moveOrig={x:t.clientX,y:t.clientY};
        jIn={x:0,y:0};
        jBase.style.left=t.clientX+'px';
        jBase.style.top=t.clientY+'px';
        jBase.classList.add('active');
        jThumb.classList.add('active');
        jThumb.style.transform='translate(-50%,-50%)';
        if(!started){started=true;heroLabel.classList.add('hidden');}
      } else if(camTid===null){
        // ── 회전 (상단 또는 이동 중 두번째 손가락 어디든) ──
        camTid=t.identifier;
        camPrev={x:t.clientX,y:t.clientY};
      }
    },{passive:false});

    renderer.domElement.addEventListener('touchmove',e=>{
      e.preventDefault();

      // 핀치 줌 (이동과 병행)
      if(e.touches.length>=2){
        if(!pinchOn){pinchOn=true;pinchBase=pDist(e.touches[0],e.touches[1]);}
        const nd=pDist(e.touches[0],e.touches[1]);
        camDist=Math.max(3,Math.min(12,camDist-(nd-pinchBase)*0.008));
        pinchBase=nd;
        // return하지 않음 → 이동/회전 계속 처리
      }

      for(const t of e.changedTouches){
        if(t.identifier===moveTid){
          // 조이스틱 업데이트
          let dx=t.clientX-moveOrig.x, dy=t.clientY-moveOrig.y;
          const d=Math.sqrt(dx*dx+dy*dy);
          if(d>JR){dx=dx/d*JR;dy=dy/d*JR;}
          jIn.x=dx/JR; jIn.y=dy/JR;
          jThumb.style.transform=`translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px))`;
        }
        if(t.identifier===camTid){
          // 카메라 회전 (손가락 이동한 만큼)
          yaw-=(t.clientX-camPrev.x)*0.005;
          camPrev={x:t.clientX,y:t.clientY};
        }
      }
    },{passive:false});

    renderer.domElement.addEventListener('touchend',e=>{
      if(e.touches.length<2)pinchOn=false;
      for(const t of e.changedTouches){
        if(t.identifier===moveTid){
          moveTid=null; jIn={x:0,y:0};
          jBase.classList.remove('active');
          jThumb.classList.remove('active');
          jThumb.style.transform='translate(-50%,-50%)';
        }
        if(t.identifier===camTid) camTid=null;
      }
    });

    renderer.domElement.addEventListener('touchcancel',()=>{
      moveTid=null;camTid=null;pinchOn=false;jIn={x:0,y:0};
